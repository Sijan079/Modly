{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities for Modly",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "opener:default",
    "dialog:default",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-execute"
  ]
}
